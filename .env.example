# ─── FanFundingAptos — Environment Variables ───
# Copy this file to .env.local and fill in your values.

# ─── Aptos (client-visible) ───
# The address that published the Move module on testnet.
NEXT_PUBLIC_MODULE_ADDRESS=0xYOUR_MODULE_ADDRESS_HERE

# Aptos fullnode REST URL (must end with /v1)
NEXT_PUBLIC_APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1

# ─── Pinata / IPFS ───
# Server-side JWT (used by /api/pinata/upload — never exposed to browser)
PINATA_JWT=your_pinata_jwt_here

# Client-side JWT (only if uploading directly from browser via src/lib/ipfs.ts)
NEXT_PUBLIC_PINATA_JWT=
