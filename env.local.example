# ─── FanFundingStacks — Environment Variables ───
# Fill in values after deploying the Clarity contract.

# ─── Stacks (client-visible) ───
# The deployer's STX address (the address that deployed the contract)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Contract name (default: nft-donation)
NEXT_PUBLIC_CONTRACT_NAME=nft-donation

# Hiro Stacks API URL (testnet)
NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Network: testnet | mainnet | devnet
NEXT_PUBLIC_STACKS_NETWORK=testnet

# ─── Pinata / IPFS ───
# Server-side JWT (used by /api/pinata/upload — never exposed to browser)
PINATA_JWT=your_pinata_jwt_here

# Client-side JWT (only if uploading directly from browser via src/lib/ipfs.ts)
NEXT_PUBLIC_PINATA_JWT=
